GEMINI_API_KEY=your-gemini-api-key
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=your-voice-id
# Optional: distinct voice ids per sex, if your ElevenLabs account has them.
# If left empty, ELEVENLABS_VOICE_ID is reused and macho/hembra are only
# differentiated via pitch shifting.
ELEVENLABS_VOICE_ID_MACHO=
ELEVENLABS_VOICE_ID_HEMBRA=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

CORS_ORIGINS=http://localhost:5173

MAX_UPLOAD_MB=8
CLEANUP_MAX_AGE_MINUTES=120
CLEANUP_INTERVAL_MINUTES=30
