GEMINI_API_KEY=your-gemini-api-key
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Which service generates the pet's voice: "elevenlabs" or "gemini".
TTS_PROVIDER=elevenlabs

# Only needed when TTS_PROVIDER=elevenlabs.
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=your-voice-id
# Optional: comma-separated pools of voice ids per sex (add a few voices from
# your ElevenLabs Voice Library for variety, requires a paid ElevenLabs plan
# to use Voice Library voices via the API — voices you clone yourself work on
# the free plan too). A different voice is picked at random from the matching
# pool on every generation. If left empty, ELEVENLABS_VOICE_ID is reused.
# Example: ELEVENLABS_VOICE_ID_MACHO=voiceIdA,voiceIdB,voiceIdC
ELEVENLABS_VOICE_ID_MACHO=
ELEVENLABS_VOICE_ID_HEMBRA=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Only needed when TTS_PROVIDER=gemini. Uses the same GEMINI_API_KEY above.
# Voice pools per sex, comma-separated; one is picked at random per
# generation. See Gemini's speech-generation docs for the full voice list.
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI_TTS_VOICES_MACHO=Puck,Fenrir,Orus
GEMINI_TTS_VOICES_HEMBRA=Kore,Aoede,Leda

CORS_ORIGINS=http://localhost:5173

MAX_UPLOAD_MB=8
CLEANUP_MAX_AGE_MINUTES=120
CLEANUP_INTERVAL_MINUTES=30
